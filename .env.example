# Common infrastructure
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_HOST=db
POSTGRES_PORT=5432
NEXTCLOUD_SOURCE_DIR=/data/nextcloud
NORMALIZED_OUTPUT_DIR=/data/normalized

# OpenAI provider defaults
OPENAI_API_KEY=replace-me
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini

# API / agent chat
LLM_PROVIDER=openai
LLAMACPP_BASE_URL=http://localhost:8080/v1
LLAMACPP_API_KEY=not-needed
LLAMACPP_CHAT_MODEL=local-model
RAG_QUERY_LIMIT=8
RAG_AGENT_MAX_STEPS=6
RAG_MEMORY_PATH=/memory/MEMORY.md

# Embedder / indexer
EMBEDDING_PROVIDER=openai
LLAMACPP_EMBEDDING_BASE_URL=http://localhost:8081/v1
LLAMACPP_EMBEDDING_API_KEY=not-needed
LLAMACPP_EMBEDDING_MODEL=local-embedding-model
EMBEDDING_TOKENIZER_MODEL_ID=mixedbread-ai/mxbai-embed-large-v1
EMBEDDING_TOKENIZER_LOCAL_FILES_ONLY=true
EMBEDDING_QUERY_PREFIX=
EMBEDDING_DOCUMENT_PREFIX=
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=75
RAG_MISSING_GRACE_DAYS=7
RAG_INDEXING_VERSION=tokenizer-aligned-v1
EMBED_WATCH_DEBOUNCE_SECONDS=15
EMBED_RECONCILE_INTERVAL_SECONDS=15

# Normalizer
NORMALIZATION_BACKEND=docling
RAG_ENABLED_SUFFIXES=.pdf,.docx,.txt,.md,.jpg,.jpeg,.png
NORMALIZE_WATCH_DEBOUNCE_SECONDS=15
NORMALIZE_RECONCILE_INTERVAL_SECONDS=15
NORMALIZE_WATCH_STABILITY_CHECKS=3
NORMALIZE_WATCH_STABILITY_INTERVAL_SECONDS=2
NORMALIZE_WATCH_STABILITY_MAX_WAIT_SECONDS=30
